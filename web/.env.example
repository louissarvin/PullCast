# ===========================================
# PullCast - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ===========================================
# App Configuration
# ===========================================
VITE_APP_NAME="PullCast"
VITE_APP_URL="http://localhost:3200"
VITE_APP_TITLE="PullCast — Pull, Brag, Repeat"

# ===========================================
# API Configuration
# ===========================================
VITE_API_URL="http://localhost:3700"
VITE_API_KEY=""

# ===========================================
# Analytics (optional)
# ===========================================
# VITE_GA_ID=""
# VITE_POSTHOG_KEY=""

# ===========================================
# Web3 / Blockchain (optional)
# ===========================================
# VITE_RPC_URL=""
# VITE_CHAIN_ID=""
# VITE_CONTRACT_ADDRESS=""

# ===========================================
# Third-party Services (optional)
# ===========================================
# VITE_SUPABASE_URL=""
# VITE_SUPABASE_ANON_KEY=""
