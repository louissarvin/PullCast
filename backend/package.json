{
  "name": "backend-starter",
  "version": "1.0.0",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun index.ts",
    "dev": "bun --watch index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:push": "bunx prisma db push --config prisma/prisma.config.ts && bunx prisma generate --config prisma/prisma.config.ts",
    "db:pull": "bunx prisma db pull --config prisma/prisma.config.ts",
    "db:generate": "bunx prisma generate --config prisma/prisma.config.ts",
    "db:migrate": "bunx prisma migrate dev --name init --config prisma/prisma.config.ts",
    "test:share-card": "bun run src/lib/share-card/test-render.ts",
    "seed-corpus": "bun scripts/seed-corpus.ts",
    "test": "bun test tests/",
    "test:watch": "bun test --watch tests/"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@solana/wallet-standard-util": "^1.1.2",
    "@solana/web3.js": "^1.98.0",
    "axios": "^1.7.9",
    "bs58": "^6.0.0",
    "discord.js": "^14.16",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "fastify": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "pg": "^8.13.0",
    "satori": "^0.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.10",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "bun-types": "latest",
    "eslint": "^8.57.0",
    "prisma": "^7.0.0",
    "typescript": "^5.7.3"
  }
}
