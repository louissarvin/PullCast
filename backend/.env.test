APP_PORT=3700
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/<db-name>?schema=public"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
  # Discord (DISCORD_BOT_TOKEN, DISCORD_APP_ID required to boot)
  # Get these from https://discord.com/developers/applications
  # ---------------------------------------------------------------------------
  DISCORD_BOT_TOKEN=
  DISCORD_APP_ID=
  DISCORD_PUBLIC_KEY=
  DISCORD_DEV_GUILD_ID=

  # ---------------------------------------------------------------------------
  # Anthropic (ANTHROPIC_API_KEY required to boot)
  # ---------------------------------------------------------------------------
  ANTHROPIC_API_KEY=
  ANTHROPIC_MODEL=claude-haiku-4-5

  # ---------------------------------------------------------------------------
  # Renaiss main API
  # ---------------------------------------------------------------------------
  RENAISS_API_BASE=https://api.renaiss.xyz/v0

  # ---------------------------------------------------------------------------
  # Renaiss OS Index API (public tier: 60/min, 1000/day per IP)
  # ---------------------------------------------------------------------------
  RENAISS_INDEX_BASE=https://api.renaissos.com/v1

  # ---------------------------------------------------------------------------
  # BSC mainnet (chain ID 56)
  # BSC mainnet (chain ID 56)
  # ---------------------------------------------------------------------------
  BSC_RPC_PRIMARY=https://bsc.publicnode.com
  BSC_RPC_FALLBACK=https://rpc.ankr.com/bsc
  BSC_CHAIN_ID=56
  
  # ---------------------------------------------------------------------------
  # Indexer
  # ---------------------------------------------------------------------------
  INDEXER_POLL_INTERVAL_MS=30000
  INDEXER_TRACKED_PACKS=eden,omega,renacrypt
  
  # ---------------------------------------------------------------------------
  # Rate limits
  # ---------------------------------------------------------------------------
  DISCORD_POST_RATE_PER_CHANNEL_PER_MIN=10
  INDEX_API_DAILY_BUDGET=800
  
  # ---------------------------------------------------------------------------
  # Share card
  # ---------------------------------------------------------------------------
  SHARE_CARD_BASE_URL=http://localhost:3700/og